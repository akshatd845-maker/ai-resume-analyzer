{
  "name": "ai-resume-analyzer-backend",
  "version": "1.0.0",
  "description": "Backend server for AI Resume Analyzer",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watchAll --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "seed:jobs": "node scripts/seed-jobs.js",
    "seed:admin": "node scripts/seed-admin.js"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup/database.setup.js"
    ],
    "testTimeout": 60000,
    "verbose": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/cloudinary.js",
      "!src/config/database.js"
    ]
  },
  "keywords": [
    "resume",
    "analyzer",
    "ai",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "1.18.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "openai": "^6.45.0",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
