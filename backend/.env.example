PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb+srv://username:password@clusterName.appName.mongodb.net/?appName=clusterName
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
AI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
API_BASE_URL=http://localhost:5000/api

# Google OAuth — obtain from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match an Authorized Redirect URI in your Google Cloud Console OAuth 2.0 credentials
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Session secret for the OAuth round-trip (defaults to JWT_SECRET if not set)
SESSION_SECRET=your-session-secret-here

# Production Security Hardening & Rate Limits
FRONTEND_URL=
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=
MAX_UPLOAD_SIZE=
# Administrator Seed Credentials (development only)
ADMIN_EMAIL=
ADMIN_PASSWORD=